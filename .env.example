# Copy to .env and replace placeholders before docker compose up.
# cp .env.example .env   (Linux/macOS)
# Copy-Item .env.example .env   (PowerShell)

# --- UNIFIED CREDENTIALS ---
SHARED_USER=admin
SHARED_PASSWORD=changeme_strong_password

# --- MINIO ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme_strong_password
MINIO_BROWSER_REDIRECT_URL=http://localhost/minio/

# --- MLFLOW ---
MLFLOW_DB_USER=admin
MLFLOW_DB_PASSWORD=changeme_strong_password
MLFLOW_DB_NAME=mlflow_db

# --- AIRFLOW ---
AIRFLOW_DB_USER=admin
AIRFLOW_DB_PASSWORD=changeme_strong_password
AIRFLOW_DB_NAME=airflow
AIRFLOW_UID=5000
AIRFLOW_GID=0
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=REPLACE_WITH_FERNET_KEY

# --- POSTGRES CONNECTIONS (must match DB users/passwords above) ---
MLFLOW_DATABASE_URL=postgresql://admin:changeme_strong_password@db_mlflow/mlflow_db
AIRFLOW_DATABASE_URL=postgresql+psycopg2://admin:changeme_strong_password@db_airflow/airflow

# --- INFLUXDB ---
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=changeme_strong_password
INFLUXDB_DB=metrics_db
INFLUXDB_ORG=my-org
INFLUXDB_BUCKET_BEARING=bearing_data
# After first InfluxDB init, use the token from the UI or docker logs; must match scripts using Influx
INFLUXDB_TOKEN=REPLACE_WITH_INFLUXDB_API_TOKEN

# --- AWS (MINIO) FOR MLFLOW ---
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=changeme_strong_password
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# --- REVERSE PROXY BASE URLS ---
AIRFLOW_BASE_URL=http://localhost/airflow
GRAFANA_URL=http://localhost/grafana
